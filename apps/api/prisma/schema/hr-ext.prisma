// =============================================================================
// Enterprise HRMS — Departments, Recruitment, Training, Performance, Exit
// =============================================================================

enum JobOpeningStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TrainingEnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum PerformanceReviewStatus {
  DRAFT
  SELF_REVIEW
  MANAGER_REVIEW
  COMPLETED
}

enum ExitProcessStatus {
  RESIGNATION_SUBMITTED
  NOTICE_PERIOD
  CLEARANCE
  SETTLEMENT
  COMPLETED
}

enum HrExpenseClaimStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum EmploymentType {
  PERMANENT
  PROBATION
  CONTRACT
  INTERN
  TEMPORARY
  CONSULTANT
  DAILY_WAGE
  PART_TIME
}

model HrDepartment {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @db.VarChar(30)
  parentId    String?  @map("parent_id") @db.Uuid
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  isActive    Boolean  @default(true) @map("is_active")

  parent       HrDepartment?  @relation("HrDeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     HrDepartment[] @relation("HrDeptHierarchy")
  designations HrDesignation[]
  jobOpenings  JobOpening[]

  @@unique([hotelId, code])
  @@index([hotelId, name])
  @@map("hr_departments")
}

model HrDesignation {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  departmentId String?  @map("department_id") @db.Uuid
  name         String   @db.VarChar(100)
  level        Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  isActive     Boolean  @default(true) @map("is_active")

  department HrDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobOpenings JobOpening[]

  @@unique([hotelId, name])
  @@map("hr_designations")
}

model StaffProfile {
  id               String          @id @default(uuid()) @db.Uuid
  hotelId          String          @map("hotel_id") @db.Uuid
  staffId          String          @unique @map("staff_id") @db.Uuid
  dateOfBirth      DateTime?       @map("date_of_birth") @db.Date
  bloodGroup       String?         @map("blood_group") @db.VarChar(10)
  nationality      String?         @db.VarChar(100)
  maritalStatus    String?         @map("marital_status") @db.VarChar(30)
  employmentType   EmploymentType  @default(PERMANENT) @map("employment_type")
  panNumber        String?         @map("pan_number") @db.VarChar(20)
  aadhaarLast4     String?         @map("aadhaar_last4") @db.VarChar(4)
  passportNumber   String?         @map("passport_number") @db.VarChar(50)
  drivingLicense   String?         @map("driving_license") @db.VarChar(50)
  permanentAddress String?         @map("permanent_address") @db.Text
  currentAddress   String?         @map("current_address") @db.Text
  bankName         String?         @map("bank_name") @db.VarChar(100)
  bankAccount      String?         @map("bank_account") @db.VarChar(50)
  bankIfsc         String?         @map("bank_ifsc") @db.VarChar(20)
  pfNumber         String?         @map("pf_number") @db.VarChar(50)
  esicNumber       String?         @map("esic_number") @db.VarChar(50)
  uan              String?         @db.VarChar(50)
  reportingManagerId String?       @map("reporting_manager_id") @db.Uuid
  skills           Json?
  languages        Json?
  education        Json?
  experience       Json?
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("staff_profiles")
}

model JobOpening {
  id             String           @id @default(uuid()) @db.Uuid
  hotelId        String           @map("hotel_id") @db.Uuid
  title          String           @db.VarChar(200)
  departmentId   String?          @map("department_id") @db.Uuid
  designationId  String?          @map("designation_id") @db.Uuid
  status         JobOpeningStatus @default(OPEN)
  openings       Int              @default(1)
  description    String?          @db.Text
  requirements   String?          @db.Text
  salaryMin      Decimal?         @map("salary_min") @db.Decimal(12, 2)
  salaryMax      Decimal?         @map("salary_max") @db.Decimal(12, 2)
  postedAt       DateTime         @default(now()) @map("posted_at") @db.Timestamptz
  closesAt       DateTime?        @map("closes_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz
  isActive       Boolean          @default(true) @map("is_active")

  department  HrDepartment?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation HrDesignation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  candidates  Candidate[]

  @@index([hotelId, status])
  @@map("job_openings")
}

model Candidate {
  id           String          @id @default(uuid()) @db.Uuid
  hotelId      String          @map("hotel_id") @db.Uuid
  jobOpeningId String          @map("job_opening_id") @db.Uuid
  firstName    String          @map("first_name") @db.VarChar(100)
  lastName     String          @map("last_name") @db.VarChar(100)
  email        String          @db.VarChar(255)
  phone        String?         @db.VarChar(30)
  status       CandidateStatus @default(APPLIED)
  resumeUrl    String?         @map("resume_url") @db.VarChar(1000)
  source       String?         @db.VarChar(100)
  appliedAt    DateTime        @default(now()) @map("applied_at") @db.Timestamptz
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?       @map("deleted_at") @db.Timestamptz
  isActive     Boolean         @default(true) @map("is_active")

  jobOpening JobOpening  @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  interviews Interview[]

  @@index([hotelId, status])
  @@index([hotelId, jobOpeningId])
  @@map("candidates")
}

model Interview {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  candidateId  String   @map("candidate_id") @db.Uuid
  scheduledAt  DateTime @map("scheduled_at") @db.Timestamptz
  interviewer  String?  @db.VarChar(200)
  round        Int      @default(1)
  feedback     String?  @db.Text
  rating       Int?
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([hotelId, scheduledAt])
  @@map("interviews")
}

model OnboardingTask {
  id          String               @id @default(uuid()) @db.Uuid
  hotelId     String               @map("hotel_id") @db.Uuid
  staffId     String               @map("staff_id") @db.Uuid
  title       String               @db.VarChar(200)
  category    String               @db.VarChar(50)
  status      OnboardingTaskStatus @default(PENDING)
  dueDate     DateTime?            @map("due_date") @db.Date
  completedAt DateTime?            @map("completed_at") @db.Timestamptz
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([hotelId, staffId])
  @@map("onboarding_tasks")
}

model TrainingCourse {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  title       String   @db.VarChar(200)
  category    String   @db.VarChar(100)
  durationHrs Int      @default(1) @map("duration_hrs")
  description String?  @db.Text
  isMandatory Boolean  @default(false) @map("is_mandatory")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  isActive    Boolean  @default(true) @map("is_active")

  enrollments EmployeeTraining[]

  @@index([hotelId, category])
  @@map("training_courses")
}

model EmployeeTraining {
  id          String                   @id @default(uuid()) @db.Uuid
  hotelId     String                   @map("hotel_id") @db.Uuid
  staffId     String                   @map("staff_id") @db.Uuid
  courseId    String                   @map("course_id") @db.Uuid
  status      TrainingEnrollmentStatus @default(ENROLLED)
  progressPct Int                      @default(0) @map("progress_pct")
  completedAt DateTime?                @map("completed_at") @db.Timestamptz
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime                 @updatedAt @map("updated_at") @db.Timestamptz

  staff  Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  course TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([hotelId, staffId, courseId])
  @@map("employee_trainings")
}

model PerformanceReview {
  id           String                  @id @default(uuid()) @db.Uuid
  hotelId      String                  @map("hotel_id") @db.Uuid
  staffId      String                  @map("staff_id") @db.Uuid
  period       String                  @db.VarChar(50)
  status       PerformanceReviewStatus @default(DRAFT)
  kpiScore     Decimal?                @map("kpi_score") @db.Decimal(5, 2)
  selfRating   Int?                    @map("self_rating")
  managerRating Int?                   @map("manager_rating")
  finalScore   Decimal?                @map("final_score") @db.Decimal(5, 2)
  notes        String?                 @db.Text
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([hotelId, staffId])
  @@map("performance_reviews")
}

model HrExpenseClaim {
  id          String               @id @default(uuid()) @db.Uuid
  hotelId     String               @map("hotel_id") @db.Uuid
  staffId     String               @map("staff_id") @db.Uuid
  claimNumber String               @map("claim_number") @db.VarChar(30)
  category    String               @db.VarChar(50)
  amount      Decimal              @db.Decimal(12, 2)
  status      HrExpenseClaimStatus @default(PENDING)
  description String?              @db.Text
  claimDate   DateTime             @default(now()) @map("claim_date") @db.Date
  approvedBy  String?              @map("approved_by") @db.Uuid
  approvedAt  DateTime?            @map("approved_at") @db.Timestamptz
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([hotelId, claimNumber])
  @@index([hotelId, status])
  @@map("hr_expense_claims")
}

model ExitProcess {
  id              String            @id @default(uuid()) @db.Uuid
  hotelId         String            @map("hotel_id") @db.Uuid
  staffId         String            @map("staff_id") @db.Uuid
  status          ExitProcessStatus @default(RESIGNATION_SUBMITTED)
  resignationDate DateTime          @map("resignation_date") @db.Date
  lastWorkingDate DateTime?         @map("last_working_date") @db.Date
  reason          String?           @db.Text
  exitInterview   String?           @map("exit_interview") @db.Text
  clearanceNotes  String?           @map("clearance_notes") @db.Text
  settlementAmount Decimal?         @map("settlement_amount") @db.Decimal(14, 2)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([hotelId, status])
  @@map("exit_processes")
}

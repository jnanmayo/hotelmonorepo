// =============================================================================
// Modules 64-73: Notifications, Feedback, CRM, Marketing, Offers
// =============================================================================

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  hotelId   String             @map("hotel_id") @db.Uuid
  userId    String?            @map("user_id") @db.Uuid
  type      NotificationType
  status    NotificationStatus @default(QUEUED)
  title     String             @db.VarChar(255)
  body      String?            @db.Text
  channel   String?            @db.VarChar(50)
  metadata  Json?
  sentAt    DateTime?          @map("sent_at") @db.Timestamptz
  readAt    DateTime?          @map("read_at") @db.Timestamptz
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy String?            @map("created_by") @db.Uuid
  updatedBy String?            @map("updated_by") @db.Uuid
  deletedBy String?            @map("deleted_by") @db.Uuid
  isActive  Boolean            @default(true) @map("is_active")
  version   Int                @default(1)

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([hotelId, userId, status])
  @@index([hotelId, createdAt(sort: Desc)])
  @@map("notifications")
}

model WhatsAppLog {
  id          String             @id @default(uuid()) @db.Uuid
  hotelId     String             @map("hotel_id") @db.Uuid
  recipient   String             @db.VarChar(30)
  templateId  String?            @map("template_id") @db.VarChar(100)
  message     String?            @db.Text
  status      NotificationStatus @default(QUEUED)
  providerRef String?            @map("provider_ref") @db.VarChar(255)
  errorMessage String?           @map("error_message") @db.Text
  sentAt      DateTime?          @map("sent_at") @db.Timestamptz
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy   String?            @map("created_by") @db.Uuid
  updatedBy   String?            @map("updated_by") @db.Uuid
  deletedBy   String?            @map("deleted_by") @db.Uuid
  isActive    Boolean            @default(true) @map("is_active")
  version     Int                @default(1)

  @@index([hotelId, createdAt(sort: Desc)])
  @@index([hotelId, status])
  @@map("whatsapp_logs")
}


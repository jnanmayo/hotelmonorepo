// =============================================================================
// Modules 22-33: Restaurant, F&B, Billing, Taxes, Discounts, Loyalty
// =============================================================================

model Restaurant {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @db.VarChar(20)
  description String?  @db.Text
  cuisine     String?  @db.VarChar(100)
  location    String?  @db.VarChar(255)
  outletType  String   @default("RESTAURANT") @map("outlet_type") @db.VarChar(50)
  gstNumber   String?  @map("gst_number") @db.VarChar(30)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  hotel          Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  tables         RestaurantTable[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  bills          Bill[]

  @@unique([hotelId, code])
  @@map("restaurants")
}

model RestaurantTable {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  tableNumber  String   @map("table_number") @db.VarChar(20)
  capacity     Int      @default(4)
  zone         String?  @db.VarChar(50)
  isOccupied   Boolean  @default(false) @map("is_occupied")
  tableStatus  TableStatus @default(AVAILABLE) @map("table_status")
  isVip        Boolean  @default(false) @map("is_vip")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bills      Bill[]

  @@unique([hotelId, restaurantId, tableNumber])
  @@map("restaurant_tables")
}

model MenuCategory {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String   @db.VarChar(100)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@unique([hotelId, restaurantId, name])
  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  name         String   @db.VarChar(255)
  code         String   @db.VarChar(50)
  description  String?  @db.Text
  price        Decimal  @default(0) @db.Decimal(12, 2)
  imageUrl     String?  @map("image_url") @db.VarChar(1000)
  isAvailable  Boolean  @default(true) @map("is_available")
  prepTimeMins Int?     @map("prep_time_mins")
  cost         Decimal  @default(0) @db.Decimal(12, 2)
  gstRate      Decimal  @default(5) @map("gst_rate") @db.Decimal(5, 2)
  itemType     MenuItemType @default(FOOD) @map("item_type")
  allergens    Json?
  calories     Int?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category         MenuCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  kitchenOrderItems KitchenOrderItem[]
  billItems        BillItem[]
  recipe           MenuRecipe?

  @@unique([hotelId, restaurantId, code])
  @@index([hotelId, categoryId])
  @@map("menu_items")
}

model KitchenOrder {
  id           String             @id @default(uuid()) @db.Uuid
  hotelId      String             @map("hotel_id") @db.Uuid
  billId       String?            @map("bill_id") @db.Uuid
  restaurantId String?            @map("restaurant_id") @db.Uuid
  orderType    FnbOrderType       @default(DINE_IN) @map("order_type")
  roomId       String?            @map("room_id") @db.Uuid
  orderNumber  String             @map("order_number") @db.VarChar(30)
  status       KitchenOrderStatus @default(PENDING)
  priority     MaintenancePriority @default(MEDIUM)
  notes        String?            @db.Text
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy    String?            @map("created_by") @db.Uuid
  updatedBy    String?            @map("updated_by") @db.Uuid
  deletedBy    String?            @map("deleted_by") @db.Uuid
  isActive     Boolean            @default(true) @map("is_active")
  version      Int                @default(1)

  bill  Bill?              @relation(fields: [billId], references: [id], onDelete: SetNull)
  items KitchenOrderItem[]

  @@unique([hotelId, orderNumber])
  @@index([hotelId, status])
  @@map("kitchen_orders")
}

model KitchenOrderItem {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  menuItemId   String   @map("menu_item_id") @db.Uuid
  quantity     Int      @default(1)
  notes        String?  @db.Text
  status       KitchenOrderStatus @default(PENDING)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  order    KitchenOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([hotelId, orderId])
  @@map("kitchen_order_items")
}

model Bill {
  id             String     @id @default(uuid()) @db.Uuid
  hotelId        String     @map("hotel_id") @db.Uuid
  restaurantId   String?    @map("restaurant_id") @db.Uuid
  tableId        String?    @map("table_id") @db.Uuid
  guestId        String?    @map("guest_id") @db.Uuid
  reservationId  String?    @map("reservation_id") @db.Uuid
  roomId         String?    @map("room_id") @db.Uuid
  orderType      FnbOrderType @default(DINE_IN) @map("order_type")
  waiterId       String?    @map("waiter_id") @db.Uuid
  billNumber     String     @map("bill_number") @db.VarChar(30)
  status         BillStatus @default(OPEN)
  subtotal       Decimal    @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal    @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal    @default(0) @map("total_amount") @db.Decimal(12, 2)
  tipAmount      Decimal    @default(0) @map("tip_amount") @db.Decimal(12, 2)
  customNotes    String?    @map("custom_notes") @db.Text
  currency       String     @default("INR") @db.VarChar(3)
  closedAt       DateTime?  @map("closed_at") @db.Timestamptz
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz
  createdBy      String?    @map("created_by") @db.Uuid
  updatedBy      String?    @map("updated_by") @db.Uuid
  deletedBy      String?    @map("deleted_by") @db.Uuid
  isActive       Boolean    @default(true) @map("is_active")
  version        Int        @default(1)

  restaurant  Restaurant?       @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  table       RestaurantTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  guest       Guest?            @relation(fields: [guestId], references: [id], onDelete: SetNull)
  reservation Reservation?      @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  items       BillItem[]
  kitchenOrders KitchenOrder[]
  invoice     Invoice?

  @@unique([hotelId, billNumber])
  @@index([hotelId, status])
  @@index([hotelId, guestId])
  @@map("bills")
}

model BillItem {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  billId      String   @map("bill_id") @db.Uuid
  menuItemId  String?  @map("menu_item_id") @db.Uuid
  description String   @db.VarChar(255)
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  taxAmount   Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  customizations Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  bill     Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([hotelId, billId])
  @@map("bill_items")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  hotelId        String        @map("hotel_id") @db.Uuid
  guestId        String?       @map("guest_id") @db.Uuid
  reservationId  String?       @map("reservation_id") @db.Uuid
  billId         String?       @unique @map("bill_id") @db.Uuid
  invoiceNumber  String        @map("invoice_number") @db.VarChar(30)
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount  Decimal       @default(0) @map("balance_amount") @db.Decimal(12, 2)
  currency       String        @default("INR") @db.VarChar(3)
  dueDate        DateTime?     @map("due_date") @db.Date
  issuedAt       DateTime?     @map("issued_at") @db.Timestamptz
  pdfUrl         String?       @map("pdf_url") @db.VarChar(1000)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz
  createdBy      String?       @map("created_by") @db.Uuid
  updatedBy      String?       @map("updated_by") @db.Uuid
  deletedBy      String?       @map("deleted_by") @db.Uuid
  isActive       Boolean       @default(true) @map("is_active")
  version        Int           @default(1)

  guest       Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  bill        Bill?        @relation(fields: [billId], references: [id], onDelete: SetNull)
  payments    Payment[]
  lineItems   InvoiceLineItem[]

  @@unique([hotelId, invoiceNumber])
  @@index([hotelId, status])
  @@index([hotelId, guestId])
  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  hotelId       String        @map("hotel_id") @db.Uuid
  guestId       String?       @map("guest_id") @db.Uuid
  invoiceId     String?       @map("invoice_id") @db.Uuid
  reservationId String?       @map("reservation_id") @db.Uuid
  paymentNumber String        @map("payment_number") @db.VarChar(30)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("INR") @db.VarChar(3)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?       @map("gateway_ref") @db.VarChar(255)
  gatewayData   Json?         @map("gateway_data")
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz
  createdBy     String?       @map("created_by") @db.Uuid
  updatedBy     String?       @map("updated_by") @db.Uuid
  deletedBy     String?       @map("deleted_by") @db.Uuid
  isActive      Boolean       @default(true) @map("is_active")
  version       Int           @default(1)

  guest   Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@unique([hotelId, paymentNumber])
  @@index([hotelId, status])
  @@index([hotelId, guestId])
  @@index([hotelId, method])
  @@map("payments")
}

model Tax {
  id         String   @id @default(uuid()) @db.Uuid
  hotelId    String   @map("hotel_id") @db.Uuid
  name       String   @db.VarChar(100)
  code       String   @db.VarChar(20)
  type       TaxType
  rate       Decimal  @db.Decimal(8, 4)
  isInclusive Boolean @default(false) @map("is_inclusive")
  appliesTo  String?  @map("applies_to") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdBy  String?  @map("created_by") @db.Uuid
  updatedBy  String?  @map("updated_by") @db.Uuid
  deletedBy  String?  @map("deleted_by") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  version    Int      @default(1)

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, code])
  @@map("taxes")
}

model Discount {
  id          String       @id @default(uuid()) @db.Uuid
  hotelId     String       @map("hotel_id") @db.Uuid
  name        String       @db.VarChar(100)
  code        String       @db.VarChar(50)
  type        DiscountType
  value       Decimal      @db.Decimal(12, 4)
  minAmount   Decimal?     @map("min_amount") @db.Decimal(12, 2)
  maxDiscount Decimal?     @map("max_discount") @db.Decimal(12, 2)
  startsAt    DateTime?    @map("starts_at") @db.Timestamptz
  endsAt      DateTime?    @map("ends_at") @db.Timestamptz
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz
  createdBy   String?      @map("created_by") @db.Uuid
  updatedBy   String?      @map("updated_by") @db.Uuid
  deletedBy   String?      @map("deleted_by") @db.Uuid
  isActive    Boolean      @default(true) @map("is_active")
  version     Int          @default(1)

  @@unique([hotelId, code])
  @@map("discounts")
}

model Coupon {
  id            String     @id @default(uuid()) @db.Uuid
  hotelId       String     @map("hotel_id") @db.Uuid
  code          String     @db.VarChar(50)
  name          String     @db.VarChar(100)
  type          CouponType
  value         Decimal    @db.Decimal(12, 4)
  maxUses       Int?       @map("max_uses")
  usedCount     Int        @default(0) @map("used_count")
  minAmount     Decimal?   @map("min_amount") @db.Decimal(12, 2)
  startsAt      DateTime?  @map("starts_at") @db.Timestamptz
  endsAt        DateTime?  @map("ends_at") @db.Timestamptz
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?  @map("deleted_at") @db.Timestamptz
  createdBy     String?    @map("created_by") @db.Uuid
  updatedBy     String?    @map("updated_by") @db.Uuid
  deletedBy     String?    @map("deleted_by") @db.Uuid
  isActive      Boolean    @default(true) @map("is_active")
  version       Int        @default(1)

  reservations Reservation[]

  @@unique([hotelId, code])
  @@map("coupons")
}

model LoyaltyProgram {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  name        String   @db.VarChar(100)
  pointsPerRupee Decimal @default(1) @map("points_per_rupee") @db.Decimal(8, 4)
  redemptionRate Decimal @default(0.25) @map("redemption_rate") @db.Decimal(8, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  accounts LoyaltyAccount[]

  @@index([hotelId])
  @@map("loyalty_programs")
}

model LoyaltyAccount {
  id        String         @id @default(uuid()) @db.Uuid
  hotelId   String         @map("hotel_id") @db.Uuid
  guestId   String         @unique @map("guest_id") @db.Uuid
  programId String         @map("program_id") @db.Uuid
  tier      MembershipTier @default(SILVER)
  balance   Decimal        @default(0) @db.Decimal(12, 2)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?      @map("deleted_at") @db.Timestamptz
  createdBy String?        @map("created_by") @db.Uuid
  updatedBy String?        @map("updated_by") @db.Uuid
  deletedBy String?        @map("deleted_by") @db.Uuid
  isActive  Boolean        @default(true) @map("is_active")
  version   Int            @default(1)

  guest        Guest               @relation(fields: [guestId], references: [id], onDelete: Cascade)
  program      LoyaltyProgram      @relation(fields: [programId], references: [id], onDelete: Restrict)
  transactions LoyaltyTransaction[]

  @@index([hotelId, tier])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id          String     @id @default(uuid()) @db.Uuid
  hotelId     String     @map("hotel_id") @db.Uuid
  accountId   String     @map("account_id") @db.Uuid
  type        LoyaltyType
  points      Decimal    @db.Decimal(12, 2)
  balanceAfter Decimal   @map("balance_after") @db.Decimal(12, 2)
  reference   String?    @db.VarChar(100)
  description String?    @db.VarChar(500)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz
  createdBy   String?    @map("created_by") @db.Uuid
  updatedBy   String?    @map("updated_by") @db.Uuid
  deletedBy   String?    @map("deleted_by") @db.Uuid
  isActive    Boolean    @default(true) @map("is_active")
  version     Int        @default(1)

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([hotelId, accountId, createdAt(sort: Desc)])
  @@map("loyalty_transactions")
}

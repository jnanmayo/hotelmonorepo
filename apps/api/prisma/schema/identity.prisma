// =============================================================================
// Modules 2-5: User Management, Roles, Permissions, Authentication
// =============================================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(30)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(1000)
  gender          Gender?
  isSuperAdmin    Boolean   @default(false) @map("is_super_admin")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  isMfaEnabled    Boolean   @default(false) @map("is_mfa_enabled")
  mfaSecret       String?   @map("mfa_secret") @db.VarChar(255)
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  lockedUntil     DateTime? @map("locked_until") @db.Timestamptz
  failedAttempts  Int       @default(0) @map("failed_attempts")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid
  deletedBy       String?   @map("deleted_by") @db.Uuid
  isActive        Boolean   @default(true) @map("is_active")
  version         Int       @default(1)

  staff            Staff?
  guestProfile     Guest?
  refreshTokens    RefreshToken[]
  oauthAccounts    OAuthAccount[]
  passwordResets   PasswordReset[]
  userRoles        UserRole[]
  loginHistory     LoginHistory[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  otpVerifications OtpVerification[]
  userSessions     UserSession[]
  trustedDevices   TrustedDevice[]
  apiKeys          ApiKey[]
  securityEvents   SecurityEvent[]
  passwordHistory  PasswordHistory[]

  @@index([deletedAt])
  @@index([isActive, isSuperAdmin])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  hotelId     String?      @map("hotel_id") @db.Uuid
  name        String       @db.VarChar(100)
  code        UserRoleType
  description String?      @db.Text
  isSystem    Boolean      @default(false) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz
  createdBy   String?      @map("created_by") @db.Uuid
  updatedBy   String?      @map("updated_by") @db.Uuid
  deletedBy   String?      @map("deleted_by") @db.Uuid
  isActive    Boolean      @default(true) @map("is_active")
  version     Int          @default(1)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([hotelId, name])
  @@unique([hotelId, code])
  @@index([hotelId, isActive])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  module      String   @db.VarChar(50)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  key         String   @unique @db.VarChar(150)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  rolePermissions RolePermission[]

  @@index([module, resource])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  hotelId   String?  @map("hotel_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  deletedBy String?  @map("deleted_by") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  version   Int      @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, hotelId])
  @@index([hotelId, userId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  deviceInfo String?   @map("device_info") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdBy  String?   @map("created_by") @db.Uuid
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedBy  String?   @map("deleted_by") @db.Uuid
  isActive   Boolean   @default(true) @map("is_active")
  version    Int       @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String   @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  accessToken    String?  @map("access_token") @db.Text
  refreshToken   String?  @map("refresh_token") @db.Text
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  deletedBy      String?  @map("deleted_by") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  version        Int      @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  isActive  Boolean   @default(true) @map("is_active")
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, expiresAt])
  @@map("password_resets")
}

// Module 84: Login History
model LoginHistory {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  hotelId   String?     @map("hotel_id") @db.Uuid
  status    LoginStatus
  ipAddress String?     @map("ip_address") @db.VarChar(45)
  userAgent String?     @map("user_agent") @db.VarChar(500)
  device    String?     @db.VarChar(100)
  location  String?     @db.VarChar(255)
  failureReason String? @map("failure_reason") @db.VarChar(255)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?   @map("deleted_at") @db.Timestamptz
  createdBy String?     @map("created_by") @db.Uuid
  updatedBy String?     @map("updated_by") @db.Uuid
  deletedBy String?     @map("deleted_by") @db.Uuid
  isActive  Boolean     @default(true) @map("is_active")
  version   Int         @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([hotelId, createdAt(sort: Desc)])
  @@map("login_history")
}

enum EventLeadStatus {
  NEW
  ASSIGNED
  VENUE_VISIT
  PROPOSAL
  QUOTATION
  NEGOTIATION
  CONFIRMED
  ADVANCE_PAID
  PLANNING
  OPERATIONS
  EXECUTION
  BILLING
  COMPLETED
  LOST
}

enum EventLeadSource {
  WEBSITE
  PHONE
  WALK_IN
  EMAIL
  WHATSAPP
  FACEBOOK
  INSTAGRAM
  GOOGLE_ADS
  REFERRAL
  TRAVEL_AGENT
  CORPORATE_SALES
  STORE
  OTHER
}

enum EventQuotationStatus {
  DRAFT
  SENT
  REVISION
  APPROVED
  REJECTED
  EXPIRED
}

enum EventTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum EventTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventPaymentType {
  BOOKING_ADVANCE
  STAGE_PAYMENT
  SECURITY_DEPOSIT
  FINAL_SETTLEMENT
  REFUND
}

enum HallCalendarBlockType {
  BOOKING
  BLOCKED
  MAINTENANCE
  TENTATIVE
}

enum EventVendorCategory {
  DECORATOR
  PHOTOGRAPHER
  DJ
  BAND
  FLORIST
  SOUND
  LIGHTING
  SECURITY
  TRANSPORT
  OTHER
}

model BanquetHall {
  id                  String   @id @default(uuid()) @db.Uuid
  hotelId             String   @map("hotel_id") @db.Uuid
  hallCode            String   @map("hall_code") @db.VarChar(30)
  name                String   @db.VarChar(150)
  description         String?  @db.Text
  images              Json?
  capacity            Int      @default(100)
  minGuests           Int      @default(20) @map("min_guests")
  maxGuests           Int      @default(500) @map("max_guests")
  theatreCapacity     Int?     @map("theatre_capacity")
  classroomCapacity   Int?     @map("classroom_capacity")
  roundTableCapacity  Int?     @map("round_table_capacity")
  uShapeCapacity      Int?     @map("u_shape_capacity")
  boardRoomCapacity   Int?     @map("board_room_capacity")
  floorPlanUrl        String?  @map("floor_plan_url") @db.VarChar(1000)
  tour360Url          String?  @map("tour_360_url") @db.VarChar(1000)
  amenities           Json?
  baseRate            Decimal  @default(0) @map("base_rate") @db.Decimal(12, 2)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz
  isActive            Boolean  @default(true) @map("is_active")

  availability        HallAvailability[]
  bookings            BanquetBooking[]
  quotations          EventQuotation[]
  events              Event[]
  preferredByLeads    EventLead[]
  preferredByClients  EventClient[]

  @@unique([hotelId, hallCode])
  @@index([hotelId, isActive])
  @@map("banquet_halls")
}

model HallAvailability {
  id        String                @id @default(uuid()) @db.Uuid
  hotelId   String                @map("hotel_id") @db.Uuid
  hallId    String                @map("hall_id") @db.Uuid
  blockDate DateTime              @map("block_date") @db.Date
  startTime String?               @map("start_time") @db.VarChar(10)
  endTime   String?               @map("end_time") @db.VarChar(10)
  blockType HallCalendarBlockType @default(BLOCKED) @map("block_type")
  eventId   String?               @map("event_id") @db.Uuid
  title     String?               @db.VarChar(255)
  notes     String?               @db.Text
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz

  hall  BanquetHall @relation(fields: [hallId], references: [id], onDelete: Cascade)
  event Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([hotelId, hallId, blockDate])
  @@map("hall_availability")
}

model EventLead {
  id              String          @id @default(uuid()) @db.Uuid
  hotelId         String          @map("hotel_id") @db.Uuid
  leadCode        String          @map("lead_code") @db.VarChar(30)
  clientName      String          @map("client_name") @db.VarChar(255)
  company         String?         @db.VarChar(255)
  email           String?         @db.VarChar(255)
  phone           String?         @db.VarChar(30)
  eventType       String          @map("event_type") @db.VarChar(50)
  source          EventLeadSource @default(PHONE)
  status          EventLeadStatus @default(NEW)
  expectedDate    DateTime?       @map("expected_date") @db.Date
  expectedGuests  Int?            @map("expected_guests")
  expectedRevenue Decimal?        @map("expected_revenue") @db.Decimal(14, 2)
  probability     Int             @default(30)
  assignedTo      String?         @map("assigned_to") @db.Uuid
  preferredHallId String?         @map("preferred_hall_id") @db.Uuid
  notes           String?         @db.Text
  eventId         String?         @map("event_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz
  createdBy       String?         @map("created_by") @db.Uuid

  preferredHall BanquetHall? @relation(fields: [preferredHallId], references: [id], onDelete: SetNull)
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  quotations    EventQuotation[]

  @@unique([hotelId, leadCode])
  @@index([hotelId, status])
  @@index([hotelId, source])
  @@map("event_leads")
}

model EventClient {
  id                  String   @id @default(uuid()) @db.Uuid
  hotelId             String   @map("hotel_id") @db.Uuid
  guestId             String?  @map("guest_id") @db.Uuid
  clientCode          String   @map("client_code") @db.VarChar(30)
  name                String   @db.VarChar(255)
  company             String?  @db.VarChar(255)
  gstNumber           String?  @map("gst_number") @db.VarChar(50)
  panNumber           String?  @map("pan_number") @db.VarChar(20)
  phone               String?  @db.VarChar(30)
  email               String?  @db.VarChar(255)
  address             String?  @db.Text
  preferredHallId     String?  @map("preferred_hall_id") @db.Uuid
  specialRequirements String?  @map("special_requirements") @db.Text
  documents           Json?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  guest         Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  preferredHall BanquetHall? @relation(fields: [preferredHallId], references: [id], onDelete: SetNull)
  events        Event[]
  quotations    EventQuotation[]
  contracts     EventContract[]
  payments      EventPayment[]

  @@unique([hotelId, clientCode])
  @@index([hotelId, guestId])
  @@map("event_clients")
}

model EventPackage {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  code        String   @db.VarChar(30)
  name        String   @db.VarChar(150)
  eventType   String   @map("event_type") @db.VarChar(50)
  description String?  @db.Text
  basePrice   Decimal  @default(0) @map("base_price") @db.Decimal(14, 2)
  inclusions  Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([hotelId, code])
  @@index([hotelId, eventType])
  @@map("event_packages")
}

model EventQuotation {
  id           String               @id @default(uuid()) @db.Uuid
  hotelId      String               @map("hotel_id") @db.Uuid
  quoteNumber  String               @map("quote_number") @db.VarChar(30)
  leadId       String?              @map("lead_id") @db.Uuid
  clientId     String?              @map("client_id") @db.Uuid
  eventId      String?              @map("event_id") @db.Uuid
  hallId       String?              @map("hall_id") @db.Uuid
  status       EventQuotationStatus @default(DRAFT)
  eventDate    DateTime?            @map("event_date") @db.Date
  guestCount   Int                  @default(0) @map("guest_count")
  subtotal     Decimal              @default(0) @db.Decimal(14, 2)
  taxAmount    Decimal              @default(0) @map("tax_amount") @db.Decimal(14, 2)
  discount     Decimal              @default(0) @db.Decimal(14, 2)
  totalAmount  Decimal              @default(0) @map("total_amount") @db.Decimal(14, 2)
  terms        String?              @db.Text
  validUntil   DateTime?            @map("valid_until") @db.Date
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  lead    EventLead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client  EventClient?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  event   Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  hall    BanquetHall?  @relation(fields: [hallId], references: [id], onDelete: SetNull)
  lines   EventQuotationLine[]

  @@unique([hotelId, quoteNumber])
  @@index([hotelId, status])
  @@map("event_quotations")
}

model EventQuotationLine {
  id           String   @id @default(uuid()) @db.Uuid
  quotationId  String   @map("quotation_id") @db.Uuid
  category     String   @db.VarChar(50)
  description  String   @db.VarChar(255)
  quantity     Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice    Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  amount       Decimal  @default(0) @db.Decimal(14, 2)
  sortOrder    Int      @default(0) @map("sort_order")

  quotation EventQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("event_quotation_lines")
}

model EventMenu {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  eventId   String?  @map("event_id") @db.Uuid
  name      String   @db.VarChar(150)
  mealType  String   @map("meal_type") @db.VarChar(50)
  style     String   @default("buffet") @db.VarChar(50)
  guestCount Int     @default(0) @map("guest_count")
  perPersonRate Decimal @default(0) @map("per_person_rate") @db.Decimal(12, 2)
  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)
  posSynced Boolean  @default(false) @map("pos_synced")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items EventMenuItem[]

  @@index([hotelId, eventId])
  @@map("event_menus")
}

model EventMenuItem {
  id       String  @id @default(uuid()) @db.Uuid
  menuId   String  @map("menu_id") @db.Uuid
  category String  @db.VarChar(50)
  name     String  @db.VarChar(150)
  isVeg    Boolean @default(true) @map("is_veg")
  quantity Int     @default(1)
  notes    String? @db.VarChar(255)

  menu EventMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@map("event_menu_items")
}

model EventTask {
  id          String            @id @default(uuid()) @db.Uuid
  hotelId     String            @map("hotel_id") @db.Uuid
  eventId     String            @map("event_id") @db.Uuid
  category    String            @db.VarChar(50)
  title       String            @db.VarChar(255)
  ownerId     String?           @map("owner_id") @db.Uuid
  ownerName   String?           @map("owner_name") @db.VarChar(100)
  deadline    DateTime?         @db.Timestamptz
  status      EventTaskStatus   @default(PENDING)
  priority    EventTaskPriority @default(MEDIUM)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([hotelId, eventId, status])
  @@map("event_tasks")
}

model EventResource {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  code         String   @db.VarChar(30)
  name         String   @db.VarChar(150)
  category     String   @db.VarChar(50)
  totalQty     Int      @default(0) @map("total_qty")
  availableQty Int      @default(0) @map("available_qty")
  unitCost     Decimal  @default(0) @map("unit_cost") @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  allocations EventResourceAllocation[]

  @@unique([hotelId, code])
  @@index([hotelId, category])
  @@map("event_resources")
}

model EventResourceAllocation {
  id         String   @id @default(uuid()) @db.Uuid
  hotelId    String   @map("hotel_id") @db.Uuid
  resourceId String   @map("resource_id") @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  quantity   Int      @default(1)
  allocatedAt DateTime @default(now()) @map("allocated_at") @db.Timestamptz
  returnedAt DateTime? @map("returned_at") @db.Timestamptz

  resource EventResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([hotelId, eventId])
  @@map("event_resource_allocations")
}

model EventVendor {
  id           String              @id @default(uuid()) @db.Uuid
  hotelId      String              @map("hotel_id") @db.Uuid
  name         String              @db.VarChar(200)
  category     EventVendorCategory @default(OTHER)
  contactName  String?             @map("contact_name") @db.VarChar(100)
  phone        String?             @db.VarChar(30)
  email        String?             @db.VarChar(255)
  rateCard     Json?               @map("rate_card")
  rating       Decimal             @default(0) @db.Decimal(3, 2)
  isPreferred  Boolean             @default(false) @map("is_preferred")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@index([hotelId, category])
  @@map("event_vendors")
}

model EventContract {
  id              String   @id @default(uuid()) @db.Uuid
  hotelId         String   @map("hotel_id") @db.Uuid
  eventId         String   @map("event_id") @db.Uuid
  clientId        String?  @map("client_id") @db.Uuid
  contractNumber  String   @map("contract_number") @db.VarChar(30)
  version         Int      @default(1)
  terms           String?  @db.Text
  cancellationPolicy String? @map("cancellation_policy") @db.Text
  forceMajeure    String?  @map("force_majeure") @db.Text
  signedAt        DateTime? @map("signed_at") @db.Timestamptz
  documentUrl     String?  @map("document_url") @db.VarChar(1000)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  event  Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client EventClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([hotelId, contractNumber])
  @@index([hotelId, eventId])
  @@map("event_contracts")
}

model EventPayment {
  id          String           @id @default(uuid()) @db.Uuid
  hotelId     String           @map("hotel_id") @db.Uuid
  eventId     String           @map("event_id") @db.Uuid
  clientId    String?          @map("client_id") @db.Uuid
  paymentType EventPaymentType @map("payment_type")
  amount      Decimal          @db.Decimal(14, 2)
  gstAmount   Decimal          @default(0) @map("gst_amount") @db.Decimal(14, 2)
  reference   String?          @db.VarChar(100)
  paidAt      DateTime         @default(now()) @map("paid_at") @db.Timestamptz
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  event  Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client EventClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([hotelId, eventId])
  @@map("event_payments")
}

model EventSeatingPlan {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  name      String   @default("Main Layout") @db.VarChar(100)
  layout    Json
  guestCount Int     @default(0) @map("guest_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([hotelId, eventId])
  @@map("event_seating_plans")
}

model EventChecklist {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  eventId   String?  @map("event_id") @db.Uuid
  name      String   @db.VarChar(150)
  eventType String?  @map("event_type") @db.VarChar(50)
  isTemplate Boolean @default(false) @map("is_template")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items EventChecklistItem[]

  @@index([hotelId, isTemplate])
  @@map("event_checklists")
}

model EventChecklistItem {
  id          String   @id @default(uuid()) @db.Uuid
  checklistId String   @map("checklist_id") @db.Uuid
  title       String   @db.VarChar(255)
  category    String?  @db.VarChar(50)
  isCompleted Boolean  @default(false) @map("is_completed")
  sortOrder   Int      @default(0) @map("sort_order")

  checklist EventChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("event_checklist_items")
}

model EventRoomBlock {
  id            String   @id @default(uuid()) @db.Uuid
  hotelId       String   @map("hotel_id") @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  reservationId String?  @map("reservation_id") @db.Uuid
  guestCategory String   @map("guest_category") @db.VarChar(50)
  guestName     String?  @map("guest_name") @db.VarChar(255)
  roomCount     Int      @default(1) @map("room_count")
  checkInDate   DateTime @map("check_in_date") @db.Date
  checkOutDate  DateTime @map("check_out_date") @db.Date
  rate          Decimal  @default(0) @db.Decimal(12, 2)
  pmsSynced     Boolean  @default(false) @map("pms_synced")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([hotelId, eventId])
  @@map("event_room_blocks")
}

model EventTimelineEntry {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  phase       String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  occurredAt  DateTime @map("occurred_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([hotelId, eventId, occurredAt])
  @@map("event_timeline_entries")
}

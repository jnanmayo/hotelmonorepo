// =============================================================================
// Modules 43-52: Corporate, Events, Travel Desk, Parking
// =============================================================================

model CorporateCompany {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  name         String   @db.VarChar(255)
  code         String   @db.VarChar(50)
  industry     String?  @db.VarChar(100)
  gstNumber    String?  @map("gst_number") @db.VarChar(50)
  panNumber    String?  @map("pan_number") @db.VarChar(20)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(30)
  address      String?  @db.Text
  website      String?  @db.VarChar(500)
  headOffice   String?  @map("head_office") @db.VarChar(500)
  branchOffices Json?   @map("branch_offices")
  billingAddress String? @map("billing_address") @db.Text
  whatsapp     String?  @db.VarChar(30)
  paymentTerms String?  @map("payment_terms") @db.VarChar(100)
  contractStatus String? @map("contract_status") @db.VarChar(50)
  category     String?  @db.VarChar(100)
  accountManagerId String? @map("account_manager_id") @db.Uuid
  creditLimit  Decimal  @default(0) @map("credit_limit") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  deletedBy    String?  @map("deleted_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  version      Int      @default(1)

  hotel      Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  contracts  CorporateContract[]
  employees  CorporateEmployee[]
  bookings   CorporateBooking[]
  contacts   CorpCompanyContact[]
  accountTeam CorpAccountTeam[]
  salesLeads CorpSalesLead[]
  meetings   CorpSalesMeeting[]
  activities CorpSalesActivity[]
  ratePlans  CorpRatePlan[]
  roomAllocations CorpRoomAllocation[]
  salesTasks CorpSalesTask[]
  documents  CorpSalesDocument[]
  creditAccount CorpCreditAccount?
  billingInvoices CorpBillingInvoice[]
  billingPayments CorpBillingPayment[]
  renewals   CorpContractRenewal[]
  commissions CorpSalesCommission[]
  approvals  CorpApprovalRequest[]

  @@unique([hotelId, code])
  @@map("corporate_companies")
}

model CorporateContract {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  title       String   @db.VarChar(255)
  contractNumber String @map("contract_number") @db.VarChar(50)
  rateType    String   @default("negotiated") @map("rate_type") @db.VarChar(50)
  discountPct Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  startsAt    DateTime @map("starts_at") @db.Date
  endsAt      DateTime @map("ends_at") @db.Date
  contractUrl String?  @map("contract_url") @db.VarChar(1000)
  status      CorpContractStatus @default(DRAFT)
  seasonalRates Json?  @map("seasonal_rates")
  weekendRates Json? @map("weekend_rates")
  blackoutDates Json? @map("blackout_dates")
  cancellationPolicy String? @map("cancellation_policy") @db.Text
  creditTerms String?  @map("credit_terms") @db.VarChar(100)
  paymentTerms String? @map("payment_terms") @db.VarChar(100)
  sla         String?  @db.Text
  autoRenewal Boolean  @default(false) @map("auto_renewal")
  signedAt    DateTime? @map("signed_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  company CorporateCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  renewals CorpContractRenewal[]

  @@unique([hotelId, contractNumber])
  @@index([hotelId, companyId])
  @@map("corporate_contracts")
}

model CorporateEmployee {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  guestId   String?  @map("guest_id") @db.Uuid
  firstName String   @map("first_name") @db.VarChar(100)
  lastName  String   @map("last_name") @db.VarChar(100)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(30)
  department String? @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  deletedBy String?  @map("deleted_by") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  version   Int      @default(1)

  company CorporateCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  guest   Guest?           @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([hotelId, companyId])
  @@map("corporate_employees")
}

model CorporateBooking {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  bookingCode String   @map("booking_code") @db.VarChar(30)
  totalRooms  Int      @default(1) @map("total_rooms")
  checkInDate DateTime @map("check_in_date") @db.Date
  checkOutDate DateTime @map("check_out_date") @db.Date
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(14, 2)
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  company      CorporateCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([hotelId, bookingCode])
  @@index([hotelId, companyId])
  @@map("corporate_bookings")
}

model Event {
  id          String      @id @default(uuid()) @db.Uuid
  hotelId     String      @map("hotel_id") @db.Uuid
  name        String      @db.VarChar(255)
  eventCode   String      @map("event_code") @db.VarChar(30)
  eventType   String      @map("event_type") @db.VarChar(50)
  status      EventStatus @default(INQUIRY)
  startDate   DateTime    @map("start_date") @db.Timestamptz
  endDate     DateTime    @map("end_date") @db.Timestamptz
  venue       String?     @db.VarChar(255)
  expectedGuests Int?     @map("expected_guests")
  organizerName String?   @map("organizer_name") @db.VarChar(255)
  organizerPhone String?  @map("organizer_phone") @db.VarChar(30)
  notes       String?     @db.Text
  clientId         String?     @map("client_id") @db.Uuid
  hallId           String?     @map("hall_id") @db.Uuid
  assignedTo       String?     @map("assigned_to") @db.Uuid
  expectedRevenue  Decimal?    @map("expected_revenue") @db.Decimal(14, 2)
  confirmedAt      DateTime?   @map("confirmed_at") @db.Timestamptz
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz
  createdBy   String?     @map("created_by") @db.Uuid
  updatedBy   String?     @map("updated_by") @db.Uuid
  deletedBy   String?     @map("deleted_by") @db.Uuid
  isActive    Boolean     @default(true) @map("is_active")
  version     Int         @default(1)

  banquetBookings BanquetBooking[]
  client              EventClient?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  hall                BanquetHall?              @relation(fields: [hallId], references: [id], onDelete: SetNull)
  hallAvailability    HallAvailability[]
  leads               EventLead[]
  quotations          EventQuotation[]
  menus               EventMenu[]
  tasks               EventTask[]
  resourceAllocations EventResourceAllocation[]
  contracts           EventContract[]
  payments            EventPayment[]
  seatingPlans        EventSeatingPlan[]
  checklists          EventChecklist[]
  roomBlocks          EventRoomBlock[]
  timeline            EventTimelineEntry[]

  @@unique([hotelId, eventCode])
  @@index([hotelId, status])
  @@map("events")
}

model BanquetBooking {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  hallId      String?  @map("hall_id") @db.Uuid
  hallName    String   @map("hall_name") @db.VarChar(100)
  packageName String?  @map("package_name") @db.VarChar(100)
  guestCount  Int      @default(0) @map("guest_count")
  rate        Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(14, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hall  BanquetHall? @relation(fields: [hallId], references: [id], onDelete: SetNull)

  @@index([hotelId, eventId])
  @@map("banquet_bookings")
}

model TravelDeskRequest {
  id          String              @id @default(uuid()) @db.Uuid
  hotelId     String              @map("hotel_id") @db.Uuid
  guestId     String?             @map("guest_id") @db.Uuid
  requestType String              @map("request_type") @db.VarChar(50)
  status      TravelRequestStatus @default(PENDING)
  description String?             @db.Text
  fromLocation String?            @map("from_location") @db.VarChar(255)
  toLocation  String?             @map("to_location") @db.VarChar(255)
  scheduledAt DateTime?           @map("scheduled_at") @db.Timestamptz
  amount      Decimal             @default(0) @db.Decimal(12, 2)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?           @map("deleted_at") @db.Timestamptz
  createdBy   String?             @map("created_by") @db.Uuid
  updatedBy   String?             @map("updated_by") @db.Uuid
  deletedBy   String?             @map("deleted_by") @db.Uuid
  isActive    Boolean             @default(true) @map("is_active")
  version     Int                 @default(1)

  airportPickups AirportPickup[]
  trips          Trip[]

  @@index([hotelId, status])
  @@map("travel_desk_requests")
}

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  hotelId            String        @map("hotel_id") @db.Uuid
  name               String        @db.VarChar(100)
  vehicleNumber      String        @map("vehicle_number") @db.VarChar(30)
  registrationNumber String?       @map("registration_number") @db.VarChar(30)
  vehicleType        String        @map("vehicle_type") @db.VarChar(50)
  brand              String?       @db.VarChar(50)
  model              String?       @db.VarChar(50)
  year               Int?
  capacity           Int           @default(4)
  fuelType           String?       @map("fuel_type") @db.VarChar(30)
  transmission       String?       @db.VarChar(30)
  color              String?       @db.VarChar(30)
  owner              String?       @db.VarChar(100)
  insuranceExpiry    DateTime?     @map("insurance_expiry") @db.Date
  fitnessExpiry      DateTime?     @map("fitness_expiry") @db.Date
  pucExpiry          DateTime?     @map("puc_expiry") @db.Date
  permitExpiry       DateTime?     @map("permit_expiry") @db.Date
  purchaseDate       DateTime?     @map("purchase_date") @db.Date
  currentOdometer    Int?          @map("current_odometer")
  qrCode             String?       @map("qr_code") @db.VarChar(100)
  gpsDeviceId        String?       @map("gps_device_id") @db.VarChar(100)
  vendorId           String?       @map("vendor_id") @db.Uuid
  status             VehicleStatus @default(AVAILABLE)
  driverName         String?       @map("driver_name") @db.VarChar(100)
  driverPhone        String?       @map("driver_phone") @db.VarChar(30)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?     @map("deleted_at") @db.Timestamptz
  createdBy          String?       @map("created_by") @db.Uuid
  updatedBy          String?       @map("updated_by") @db.Uuid
  deletedBy          String?       @map("deleted_by") @db.Uuid
  isActive           Boolean       @default(true) @map("is_active")
  version            Int           @default(1)

  vendor         TravelVendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  airportPickups AirportPickup[]
  trips          Trip[]
  fuelLogs       FuelLog[]
  expenses       VehicleExpense[]
  maintenanceLogs VehicleMaintenanceLog[]
  gpsLogs        GpsLog[]

  @@unique([hotelId, vehicleNumber])
  @@index([hotelId, status])
  @@map("vehicles")
}

model AirportPickup {
  id              String              @id @default(uuid()) @db.Uuid
  hotelId         String              @map("hotel_id") @db.Uuid
  reservationId   String?             @map("reservation_id") @db.Uuid
  travelRequestId String?             @map("travel_request_id") @db.Uuid
  vehicleId       String?             @map("vehicle_id") @db.Uuid
  guestName       String              @map("guest_name") @db.VarChar(255)
  guestPhone      String?             @map("guest_phone") @db.VarChar(30)
  flightNumber    String?             @map("flight_number") @db.VarChar(20)
  pickupType      String              @default("arrival") @map("pickup_type") @db.VarChar(20)
  status          AirportPickupStatus @default(SCHEDULED)
  scheduledAt     DateTime            @map("scheduled_at") @db.Timestamptz
  completedAt     DateTime?           @map("completed_at") @db.Timestamptz
  amount          Decimal             @default(0) @db.Decimal(12, 2)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz
  createdBy       String?             @map("created_by") @db.Uuid
  updatedBy       String?             @map("updated_by") @db.Uuid
  deletedBy       String?             @map("deleted_by") @db.Uuid
  isActive        Boolean             @default(true) @map("is_active")
  version         Int                 @default(1)

  reservation   Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  travelRequest TravelDeskRequest? @relation(fields: [travelRequestId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([hotelId, status])
  @@index([hotelId, scheduledAt])
  @@map("airport_pickups")
}

model ParkingSlot {
  id        String        @id @default(uuid()) @db.Uuid
  hotelId   String        @map("hotel_id") @db.Uuid
  slotNumber String       @map("slot_number") @db.VarChar(20)
  zone      String?       @db.VarChar(50)
  status    ParkingStatus @default(AVAILABLE)
  vehicleType String?     @map("vehicle_type") @db.VarChar(50)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?     @map("deleted_at") @db.Timestamptz
  createdBy String?       @map("created_by") @db.Uuid
  updatedBy String?       @map("updated_by") @db.Uuid
  deletedBy String?       @map("deleted_by") @db.Uuid
  isActive  Boolean       @default(true) @map("is_active")
  version   Int           @default(1)

  records ParkingRecord[]

  @@unique([hotelId, slotNumber])
  @@map("parking_slots")
}

model ParkingRecord {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  slotId      String   @map("slot_id") @db.Uuid
  vehicleNumber String @map("vehicle_number") @db.VarChar(30)
  guestName   String?  @map("guest_name") @db.VarChar(255)
  entryAt     DateTime @default(now()) @map("entry_at") @db.Timestamptz
  exitAt      DateTime? @map("exit_at") @db.Timestamptz
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  deletedBy   String?  @map("deleted_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)

  slot ParkingSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)

  @@index([hotelId, slotId])
  @@index([hotelId, entryAt])
  @@map("parking_records")
}

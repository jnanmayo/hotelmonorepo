// =============================================================================
// Channel Manager — OTA sync, webhooks, commissions, queue jobs
// =============================================================================

enum ChannelSyncJobType {
  INVENTORY
  RATES
  RESTRICTIONS
  PROMOTIONS
  FULL
}

enum ChannelSyncJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
  DEAD_LETTER
}

enum ChannelWebhookEventType {
  BOOKING_CREATED
  BOOKING_MODIFIED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  SYNC_SUCCESS
  SYNC_FAILED
  INVENTORY_CONFLICT
  RATE_CONFLICT
}

enum ChannelEnvironment {
  SANDBOX
  PRODUCTION
}

model ChannelRatePlanMapping {
  id               String   @id @default(uuid()) @db.Uuid
  hotelId          String   @map("hotel_id") @db.Uuid
  integrationId    String   @map("integration_id") @db.Uuid
  ratePlanId       String   @map("rate_plan_id") @db.Uuid
  externalRateCode String   @map("external_rate_code") @db.VarChar(100)
  externalRateName String?  @map("external_rate_name") @db.VarChar(200)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hotel       Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  ratePlan    RatePlan       @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([hotelId, integrationId, externalRateCode])
  @@index([hotelId, integrationId])
  @@map("channel_rate_plan_mappings")
}

model ChannelRestriction {
  id              String    @id @default(uuid()) @db.Uuid
  hotelId         String    @map("hotel_id") @db.Uuid
  integrationId   String?   @map("integration_id") @db.Uuid
  roomTypeId      String?   @map("room_type_id") @db.Uuid
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  minStay         Int?      @map("min_stay")
  maxStay         Int?      @map("max_stay")
  closeToArrival  Boolean   @default(false) @map("close_to_arrival")
  closeToDeparture Boolean  @default(false) @map("close_to_departure")
  stopSell        Boolean   @default(false) @map("stop_sell")
  bookingWindowDays Int?    @map("booking_window_days")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  hotel       Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  roomType    RoomType?       @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)

  @@index([hotelId, startDate, endDate])
  @@map("channel_restrictions")
}

model ChannelSyncLog {
  id            String            @id @default(uuid()) @db.Uuid
  hotelId       String            @map("hotel_id") @db.Uuid
  integrationId String            @map("integration_id") @db.Uuid
  jobId         String?           @map("job_id") @db.Uuid
  syncType      ChannelSyncJobType @map("sync_type")
  status        ChannelSyncStatus @default(PENDING)
  message       String?           @db.VarChar(500)
  payload       Json?
  response      Json?
  errorMessage  String?           @map("error_message") @db.Text
  startedAt     DateTime?         @map("started_at") @db.Timestamptz
  completedAt   DateTime?         @map("completed_at") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz

  hotel       Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  job         ChannelSyncJob?   @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([hotelId, integrationId, createdAt(sort: Desc)])
  @@index([hotelId, status])
  @@map("channel_sync_logs")
}

model ChannelWebhookEvent {
  id              String                  @id @default(uuid()) @db.Uuid
  hotelId         String                  @map("hotel_id") @db.Uuid
  integrationId   String?                 @map("integration_id") @db.Uuid
  eventType       ChannelWebhookEventType @map("event_type")
  provider        String                  @db.VarChar(50)
  externalRef     String?                 @map("external_ref") @db.VarChar(200)
  reservationId   String?                 @map("reservation_id") @db.Uuid
  payload         Json
  signatureValid  Boolean                 @default(true) @map("signature_valid")
  processed       Boolean                 @default(false)
  processedAt     DateTime?               @map("processed_at") @db.Timestamptz
  errorMessage    String?                 @map("error_message") @db.Text
  retryCount      Int                     @default(0) @map("retry_count")
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz

  hotel       Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  reservation Reservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([hotelId, eventType, createdAt(sort: Desc)])
  @@index([hotelId, processed])
  @@index([externalRef])
  @@map("channel_webhook_events")
}

model ChannelCommissionLog {
  id              String   @id @default(uuid()) @db.Uuid
  hotelId         String   @map("hotel_id") @db.Uuid
  integrationId   String   @map("integration_id") @db.Uuid
  reservationId   String?  @map("reservation_id") @db.Uuid
  commissionPct   Decimal  @map("commission_pct") @db.Decimal(8, 4)
  bookingAmount   Decimal  @map("booking_amount") @db.Decimal(12, 2)
  commissionAmount Decimal @map("commission_amount") @db.Decimal(12, 2)
  isPaid          Boolean  @default(false) @map("is_paid")
  paidAt          DateTime? @map("paid_at") @db.Timestamptz
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  hotel       Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  reservation Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([hotelId, integrationId])
  @@index([hotelId, isPaid])
  @@map("channel_commission_logs")
}

model ChannelSyncJob {
  id            String               @id @default(uuid()) @db.Uuid
  hotelId       String               @map("hotel_id") @db.Uuid
  integrationId String?              @map("integration_id") @db.Uuid
  jobType       ChannelSyncJobType   @map("job_type")
  status        ChannelSyncJobStatus @default(PENDING)
  priority      Int                  @default(5)
  payload       Json?
  attempts      Int                  @default(0)
  maxAttempts   Int                  @default(5) @map("max_attempts")
  lastError     String?              @map("last_error") @db.Text
  scheduledAt   DateTime             @default(now()) @map("scheduled_at") @db.Timestamptz
  startedAt     DateTime?            @map("started_at") @db.Timestamptz
  completedAt   DateTime?            @map("completed_at") @db.Timestamptz
  bullJobId     String?              @map("bull_job_id") @db.VarChar(100)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  hotel       Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  integration OtaIntegration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  syncLogs    ChannelSyncLog[]

  @@index([hotelId, status, priority, scheduledAt])
  @@index([status, scheduledAt])
  @@map("channel_sync_jobs")
}

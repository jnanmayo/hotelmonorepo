// =============================================================================
// TungaOS — Enterprise Travel Desk & Fleet Management (TMS)
// =============================================================================

model Driver {
  id               String   @id @default(uuid()) @db.Uuid
  hotelId          String   @map("hotel_id") @db.Uuid
  driverCode       String   @map("driver_code") @db.VarChar(30)
  firstName        String   @map("first_name") @db.VarChar(100)
  lastName         String   @map("last_name") @db.VarChar(100)
  photoUrl         String?  @map("photo_url") @db.VarChar(500)
  licenseNumber    String   @map("license_number") @db.VarChar(50)
  badgeNumber      String?  @map("badge_number") @db.VarChar(30)
  experienceYears  Int      @default(0) @map("experience_years")
  languages        String?  @db.VarChar(255)
  phone            String   @db.VarChar(30)
  email            String?  @db.VarChar(255)
  emergencyContact String?  @map("emergency_contact") @db.VarChar(100)
  emergencyPhone   String?  @map("emergency_phone") @db.VarChar(30)
  shift            String?  @db.VarChar(50)
  currentVehicleId String?  @map("current_vehicle_id") @db.Uuid
  performanceScore Decimal  @default(0) @map("performance_score") @db.Decimal(5, 2)
  trainingNotes    String?  @map("training_notes") @db.Text
  isOnDuty         Boolean  @default(false) @map("is_on_duty")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  deletedBy        String?  @map("deleted_by") @db.Uuid
  version          Int      @default(1)

  trips       Trip[]
  attendance  DriverAttendance[]
  gpsLogs     GpsLog[]

  @@unique([hotelId, driverCode])
  @@index([hotelId, isOnDuty])
  @@map("drivers")
}

model Trip {
  id                 String            @id @default(uuid()) @db.Uuid
  hotelId            String            @map("hotel_id") @db.Uuid
  tripNumber         String            @map("trip_number") @db.VarChar(30)
  travelRequestId    String?           @map("travel_request_id") @db.Uuid
  reservationId      String?           @map("reservation_id") @db.Uuid
  guestId            String?           @map("guest_id") @db.Uuid
  guestName          String            @map("guest_name") @db.VarChar(255)
  guestPhone         String?           @map("guest_phone") @db.VarChar(30)
  bookingId          String?           @map("booking_id") @db.VarChar(50)
  tripType           String            @map("trip_type") @db.VarChar(50)
  requestSource      String            @default("TRAVEL_DESK") @map("request_source") @db.VarChar(50)
  pickupLocation     String            @map("pickup_location") @db.VarChar(500)
  dropLocation       String            @map("drop_location") @db.VarChar(500)
  vehicleId          String?           @map("vehicle_id") @db.Uuid
  driverId           String?           @map("driver_id") @db.Uuid
  scheduledAt        DateTime          @map("scheduled_at") @db.Timestamptz
  startedAt          DateTime?         @map("started_at") @db.Timestamptz
  completedAt        DateTime?         @map("completed_at") @db.Timestamptz
  distanceKm         Decimal?          @map("distance_km") @db.Decimal(10, 2)
  estimatedMinutes   Int?              @map("estimated_minutes")
  status             TripStatus        @default(REQUESTED)
  fare               Decimal           @default(0) @db.Decimal(12, 2)
  paymentStatus      TripPaymentStatus @default(PENDING) @map("payment_status")
  specialInstructions String?          @map("special_instructions") @db.Text
  isVip              Boolean           @default(false) @map("is_vip")
  isEmergency        Boolean           @default(false) @map("is_emergency")
  corporateCompanyId String?           @map("corporate_company_id") @db.Uuid
  rating             Int?
  feedback           String?           @db.Text
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz
  createdBy          String?           @map("created_by") @db.Uuid
  updatedBy          String?           @map("updated_by") @db.Uuid
  deletedBy          String?           @map("deleted_by") @db.Uuid
  isActive           Boolean           @default(true) @map("is_active")
  version            Int               @default(1)

  travelRequest TravelDeskRequest? @relation(fields: [travelRequestId], references: [id], onDelete: SetNull)
  reservation   Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver        Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  stops         TripStop[]
  airportDetail AirportTransferDetail?
  payments      TripPayment[]
  gpsLogs       GpsLog[]

  @@unique([hotelId, tripNumber])
  @@index([hotelId, status])
  @@index([hotelId, scheduledAt])
  @@map("trips")
}

model TripStop {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  tripId      String   @map("trip_id") @db.Uuid
  stopOrder   Int      @map("stop_order")
  location    String   @db.VarChar(500)
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz
  arrivedAt   DateTime? @map("arrived_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_stops")
}

model AirportTransferDetail {
  id              String   @id @default(uuid()) @db.Uuid
  hotelId         String   @map("hotel_id") @db.Uuid
  tripId          String   @unique @map("trip_id") @db.Uuid
  flightNumber    String?  @map("flight_number") @db.VarChar(20)
  airline         String?  @db.VarChar(100)
  terminal        String?  @db.VarChar(50)
  transferType    String   @default("arrival") @map("transfer_type") @db.VarChar(20)
  arrivalTime     DateTime? @map("arrival_time") @db.Timestamptz
  departureTime   DateTime? @map("departure_time") @db.Timestamptz
  meetAndGreet    Boolean  @default(false) @map("meet_and_greet")
  luggageAssist   Boolean  @default(false) @map("luggage_assist")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("airport_transfer_details")
}

model TravelVendor {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  name         String   @db.VarChar(255)
  vendorType   String   @map("vendor_type") @db.VarChar(50)
  contactName  String?  @map("contact_name") @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  email        String?  @db.VarChar(255)
  contractRate Decimal? @map("contract_rate") @db.Decimal(12, 2)
  rating       Decimal  @default(0) @db.Decimal(3, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  vehicles Vehicle[]

  @@index([hotelId, vendorType])
  @@map("travel_vendors")
}

model FuelLog {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  vehicleId    String   @map("vehicle_id") @db.Uuid
  fillDate     DateTime @map("fill_date") @db.Timestamptz
  liters       Decimal  @db.Decimal(10, 2)
  cost         Decimal  @db.Decimal(12, 2)
  odometer     Int?
  mileage      Decimal? @db.Decimal(6, 2)
  stationName  String?  @map("station_name") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([hotelId, vehicleId])
  @@map("fuel_logs")
}

model VehicleExpense {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  expenseType String   @map("expense_type") @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2)
  expenseDate DateTime @map("expense_date") @db.Timestamptz
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String?  @map("created_by") @db.Uuid

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([hotelId, vehicleId])
  @@map("vehicle_expenses")
}

model VehicleMaintenanceLog {
  id              String   @id @default(uuid()) @db.Uuid
  hotelId         String   @map("hotel_id") @db.Uuid
  vehicleId       String   @map("vehicle_id") @db.Uuid
  maintenanceType String   @map("maintenance_type") @db.VarChar(50)
  scheduledDate   DateTime @map("scheduled_date") @db.Timestamptz
  completedDate   DateTime? @map("completed_date") @db.Timestamptz
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  odometer        Int?
  notes           String?  @db.Text
  status          String   @default("SCHEDULED") @db.VarChar(30)
  eamWorkOrderId  String?  @map("eam_work_order_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([hotelId, vehicleId])
  @@map("vehicle_maintenance_logs")
}

model GpsLog {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  vehicleId String?  @map("vehicle_id") @db.Uuid
  driverId  String?  @map("driver_id") @db.Uuid
  tripId    String?  @map("trip_id") @db.Uuid
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  speed     Decimal? @db.Decimal(6, 2)
  heading   Decimal? @db.Decimal(6, 2)
  recordedAt DateTime @map("recorded_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver  Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  trip    Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([hotelId, tripId])
  @@index([hotelId, vehicleId, recordedAt])
  @@map("gps_logs")
}

model TripPayment {
  id            String            @id @default(uuid()) @db.Uuid
  hotelId       String            @map("hotel_id") @db.Uuid
  tripId        String            @map("trip_id") @db.Uuid
  amount        Decimal           @db.Decimal(12, 2)
  paymentMethod String            @map("payment_method") @db.VarChar(30)
  paymentStatus TripPaymentStatus @default(PENDING) @map("payment_status")
  reference     String?           @db.VarChar(100)
  paidAt        DateTime?         @map("paid_at") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([hotelId, tripId])
  @@map("trip_payments")
}

model DriverAttendance {
  id        String   @id @default(uuid()) @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  shiftDate DateTime @map("shift_date") @db.Date
  checkIn   DateTime? @map("check_in") @db.Timestamptz
  checkOut  DateTime? @map("check_out") @db.Timestamptz
  status    String   @default("PRESENT") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([hotelId, driverId, shiftDate])
  @@map("driver_attendance")
}

model ShuttleRoute {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  stops       Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  schedules ShuttleSchedule[]

  @@index([hotelId])
  @@map("shuttle_routes")
}

model ShuttleSchedule {
  id         String   @id @default(uuid()) @db.Uuid
  hotelId    String   @map("hotel_id") @db.Uuid
  routeId    String   @map("route_id") @db.Uuid
  vehicleId  String?  @map("vehicle_id") @db.Uuid
  driverId   String?  @map("driver_id") @db.Uuid
  dayOfWeek  Int      @map("day_of_week")
  departTime String   @map("depart_time") @db.VarChar(10)
  capacity   Int      @default(12)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  route ShuttleRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([hotelId, routeId])
  @@map("shuttle_schedules")
}

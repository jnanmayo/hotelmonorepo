{
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "apps/web/$1" }],
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo build --filter=@tungaos/web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs"
}
